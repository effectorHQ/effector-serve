{
  "name": "@effectorhq/serve",
  "version": "0.1.0",
  "description": "Runtime MCP server with typed validation, capability discovery, and composition",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "effector-serve": "bin/effector-serve.js"
  },
  "files": [
    "src/",
    "bin/",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "node --check src/*.js src/tools/*.js bin/*.js",
    "start": "node bin/effector-serve.js",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "effector",
    "effectorhq",
    "mcp",
    "openclaw",
    "ai-agents",
    "type-safety",
    "runtime-validation",
    "capability-discovery",
    "composition",
    "permission-enforcement",
    "telemetry",
    "typed-tools"
  ],
  "author": "effectorHQ Contributors",
  "license": "Apache-2.0",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/effectorHQ"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/effectorHQ/effector-serve.git"
  },
  "bugs": {
    "url": "https://github.com/effectorHQ/effector-serve/issues"
  },
  "homepage": "https://github.com/effectorHQ/effector-serve#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@effectorhq/core": "file:../effector-core",
    "@effectorhq/skill-mcp": "file:../openclaw-mcp",
    "@effectorhq/compose": "file:../effector-compose",
    "@effectorhq/types": "file:../effector-types"
  }
}
